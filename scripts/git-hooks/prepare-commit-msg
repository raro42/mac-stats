#!/bin/sh
# prepare-commit-msg: remove Cursor/agent attribution from commit messages.
# Install: ./scripts/install-git-hooks.sh
set -e
msg_file="$1"
[ -f "$msg_file" ] || exit 0
tmp=$(mktemp)
# Strip Cursor/agent attribution trailers (any casing / spacing).
grep -v -E \
  -e '^[[:space:]]*Co-authored-by:[[:space:]]*.*[Cc]ursor' \
  -e '^[[:space:]]*Co-authored-by:[[:space:]]*cursoragent@cursor\.com' \
  -e '^[[:space:]]*Made-with:[[:space:]]*.*[Cc]ursor' \
  -e '^[[:space:]]*Signed-off-by:[[:space:]]*.*[Cc]ursor' \
  "$msg_file" > "$tmp" || true
if [ -s "$tmp" ]; then
  mv "$tmp" "$msg_file"
else
  rm -f "$tmp"
fi
exit 0
